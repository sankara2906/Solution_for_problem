public class ASCII {

    public static void main(String[] args) {

        String s = "code";
        int score = 0;

        for (int i = 0; i < s.length() - 1; i++) {

            int diff = Math.abs(s.charAt(i + 1) - s.charAt(i));
            score = score + diff;

        }

        System.out.println(score);
    }
}
